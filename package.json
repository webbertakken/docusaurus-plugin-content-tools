{
  "name": "docusaurus-plugin-content-tools",
  "version": "0.1.0",
  "description": "Easy overview with routes to your tools",
  "keywords": [
    "docusaurus",
    "plugin",
    "theme",
    "tools",
    "homepage"
  ],
  "homepage": "https://github.com/webbertakken/docusaurus-plugin-content-tools",
  "bugs": "https://github.com/webbertakken/docusaurus-plugin-content-tools/issues",
  "repository": "https://github.com/webbertakken/docusaurus-plugin-content-tools.git",
  "author": "Webber <webber.nl@gmail.com>",
  "license": "MIT",
  "main": "lib/index.js",
  "types": "src/types/index.d.ts",
  "files": [
    "src/*",
    "lib/*"
  ],
  "scripts": {
    "build": "concurrently yarn:build:plugin yarn:build:theme yarn:build:assets",
    "watch": "concurrently \"yarn:build:plugin --watch\" \"yarn:build:theme --watch\" \"yarn:build:assets --watch\"",
    "build:plugin": "tsc",
    "build:theme": "tsc --build tsconfig.theme.json",
    "build:assets": "node scripts/copyUntypedFiles.mjs",
    "test": "node scripts/ensure-husky.mjs && vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "yarn oxlint --deny-warnings --report-unused-disable-directives",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "typecheck:tsgo": "tsgo --noEmit",
    "setup:hooks": "node scripts/ensure-husky.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.@(ts|tsx|mts|js|jsx|mjs|cjs)": [
      "oxlint --fix --quiet",
      "oxfmt --write"
    ],
    "*.@(json|jsonc|json5|md|mdx|yaml|yml|css|scss|sass|html|toml)": "oxfmt --write",
    ".github/workflows/*.@(yml|yaml)": "actionlint"
  },
  "dependencies": {
    "@docusaurus/core": "2.0.0-beta.21",
    "@docusaurus/theme-classic": "^2.0.0-beta.21",
    "@docusaurus/theme-common": "2.0.0-beta.21",
    "@docusaurus/theme-translations": "2.0.0-beta.21",
    "@docusaurus/types": "2.0.0-beta.21",
    "@docusaurus/utils-validation": "^2.0.0-beta.21"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^2.0.0-beta.21",
    "@octokit/types": "^6.34.0",
    "@types/node": "^17.0.35",
    "@types/react": "^18.0.10",
    "@typescript/native-preview": "^7.0.0-dev.20260505.1",
    "@vitest/coverage-istanbul": "^3",
    "chokidar": "^3.5.3",
    "classnames": "^2.3.1",
    "concurrently": "^7.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "fs-extra": "^10.1.0",
    "happy-dom": "^20.9.0",
    "husky": "9",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^3"
  },
  "peerDependencies": {
    "react": "^16.8.4||^17.0.0||^18.0.0",
    "react-dom": "^16.8.4||^17.0.0||^18.0.0"
  },
  "packageManager": "yarn@4.14.1",
  "dependenciesMeta": {
    "core-js": {
      "built": true
    },
    "core-js-pure": {
      "built": true
    }
  }
}
